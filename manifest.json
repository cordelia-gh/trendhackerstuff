{
  "manifest_version": 3,
  "name": "Skibidi Scroll: TrendHacker2026",
  "version": "1.0",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.instagram.com/*",
        "https://*.tiktok.com/*",
        "https://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "skibidi-toilet-song.mp3",
        "cursed.mp3",
        "skibidi.gif",
        "brainrot-cat.gif",
        "brainrot-scuba.gif",
        "brainrot-horse.gif"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://*.tiktok.com/*",
    "https://*.youtube.com/*"
  ]
}